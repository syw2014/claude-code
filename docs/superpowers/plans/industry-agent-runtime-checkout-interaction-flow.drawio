<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="drawio" version="26.0.0">
  <diagram name="扫码借书完整交互链路">
    <mxGraphModel dx="2400" dy="1700" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2400" pageHeight="1700" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" value="示例：扫码借书，读者有逾期 WARN，人工确认后执行 checkout_book" style="text;html=1;strokeColor=none;fillColor=none;fontSize=26;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="420" y="20" width="1560" height="48" as="geometry" />
        </mxCell>
        <mxCell id="legend" value="绿色：正常主链路　黄色：判断/规则　红色：人工确认/异常　紫色：工具/行业能力　灰色：数据源　虚线：循环或异步链路" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F6F6F3;strokeColor=#999999;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="520" y="78" width="1360" height="42" as="geometry" />
        </mxCell>

        <mxCell id="n1" value="1. 前端提交消息&#xa;POST /sessions/:id/messages&#xa;input: 扫码借书，读者A，馆藏B" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE6CC;strokeColor=#D77757;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="80" y="185" width="250" height="90" as="geometry" />
        </mxCell>
        <mxCell id="n2" value="2. API 中间件&#xa;Auth / Tenant / Idempotency&#xa;生成 requestId" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#5769F7;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="420" y="185" width="230" height="90" as="geometry" />
        </mxCell>
        <mxCell id="n3" value="3. 写入请求事实&#xa;agent_messages(user)&#xa;agent_tasks(queued)&#xa;Redis task hot state" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#5769F7;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="740" y="185" width="240" height="100" as="geometry" />
        </mxCell>
        <mxCell id="n4" value="4. AgentRuntime.run&#xa;创建 SessionContext&#xa;挂载 ContextEnvelope" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#4B8F63;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="1080" y="185" width="240" height="90" as="geometry" />
        </mxCell>
        <mxCell id="n5" value="5. SemanticMapper&#xa;scene=CIRCULATION_CHECKOUT&#xa;confidence=0.97&#xa;pathType=fast" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EADCF8;strokeColor=#8F62C9;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="1420" y="185" width="250" height="110" as="geometry" />
        </mxCell>
        <mxCell id="n6" value="6. BizRefBuilder&#xa;读取 Reader A / BookCopy B&#xa;构建 BizRef + FactSet" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EADCF8;strokeColor=#8F62C9;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="1780" y="185" width="250" height="100" as="geometry" />
        </mxCell>
        <mxCell id="bizdb" value="行业业务系统&#xa;Reader: overdueCount=2&#xa;BookCopy: AVAILABLE" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="2070" y="185" width="230" height="100" as="geometry" />
        </mxCell>

        <mxCell id="d_fast" value="7. 快路径命中?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1040" y="380" width="180" height="110" as="geometry" />
        </mxCell>
        <mxCell id="slow" value="慢路径分支&#xa;QueryRuntime → Prompt/Memory/Knowledge → LLM&#xa;缺参数时追问；复杂争议时规划" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="1320" y="380" width="310" height="105" as="geometry" />
        </mxCell>
        <mxCell id="tool_loop" value="ToolLoop 循环&#xa;模型决定工具 → 执行 → 结果回传 → 下一步" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#4B8F63;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="1710" y="380" width="290" height="95" as="geometry" />
        </mxCell>
        <mxCell id="subagent" value="SubAgent 分支&#xa;状态争议 / 费用争议 / 异常工单&#xa;子 Agent 继承 traceId" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EADCF8;strokeColor=#8F62C9;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="2045" y="380" width="260" height="105" as="geometry" />
        </mxCell>

        <mxCell id="rule" value="8. RuleEngine.check(checkout_book)&#xa;读取 session 绑定 ruleVersion&#xa;结果: WARN" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="790" y="575" width="280" height="95" as="geometry" />
        </mxCell>
        <mxCell id="rule_decision" value="规则结果" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1125" y="575" width="155" height="95" as="geometry" />
        </mxCell>
        <mxCell id="blocked" value="BLOCKED 分支&#xa;不执行工具&#xa;TaskStatus=failed/rejected&#xa;SSE error" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="1335" y="575" width="230" height="95" as="geometry" />
        </mxCell>
        <mxCell id="perm" value="9. PermissionGate&#xa;medium + WARN&#xa;requiredConfirmLevel=explicit_confirm" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="790" y="745" width="280" height="95" as="geometry" />
        </mxCell>
        <mxCell id="perm_decision" value="确认等级" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1125" y="745" width="155" height="95" as="geometry" />
        </mxCell>
        <mxCell id="auto" value="auto 分支&#xa;low 或 medium+PASS&#xa;直接执行工具" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#4B8F63;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="1335" y="745" width="230" height="85" as="geometry" />
        </mxCell>
        <mxCell id="hitl" value="10. HumanConfirmManager&#xa;写 agent_human_confirms(pending)&#xa;SSE permission_required" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="790" y="925" width="300" height="105" as="geometry" />
        </mxCell>
        <mxCell id="frontend_confirm" value="11. 馆员确认卡片&#xa;approve / reject / timeout" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE6CC;strokeColor=#D77757;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="420" y="925" width="250" height="90" as="geometry" />
        </mxCell>
        <mxCell id="confirm_decision" value="确认结果" style="rhombus;whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1125" y="925" width="155" height="100" as="geometry" />
        </mxCell>
        <mxCell id="reject" value="reject / timeout 分支&#xa;更新 agent_human_confirms&#xa;TaskStatus=rejected/timeout&#xa;SSE done" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="1335" y="925" width="250" height="105" as="geometry" />
        </mxCell>

        <mxCell id="tool" value="12. Tool Execute&#xa;checkout_book(readerId=A, copyId=B)&#xa;写 agent_tool_calls(executing)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EADCF8;strokeColor=#8F62C9;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="790" y="1115" width="310" height="105" as="geometry" />
        </mxCell>
        <mxCell id="checkout_api" value="图书馆借阅服务&#xa;libraryApi.checkout()" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="420" y="1120" width="250" height="85" as="geometry" />
        </mxCell>
        <mxCell id="tool_ok" value="工具成功?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1150" y="1120" width="150" height="100" as="geometry" />
        </mxCell>
        <mxCell id="retry" value="可重试失败&#xa;ErrorHandler.retry&#xa;写 error audit&#xa;回到 Tool Execute" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="1375" y="1115" width="230" height="105" as="geometry" />
        </mxCell>
        <mxCell id="fail" value="不可重试失败&#xa;TaskStatus=failed&#xa;SSE error" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="1665" y="1115" width="220" height="95" as="geometry" />
        </mxCell>
        <mxCell id="next" value="还需要下一步?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#4B8F63;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1150" y="1310" width="150" height="100" as="geometry" />
        </mxCell>
        <mxCell id="response" value="13. Final Response&#xa;写 assistant message&#xa;TaskStatus=succeeded&#xa;SSE done" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#4B8F63;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="790" y="1310" width="300" height="105" as="geometry" />
        </mxCell>
        <mxCell id="sse" value="SSE Stream&#xa;task_queued / intent_detected / permission_required&#xa;tool_completed / done" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="420" y="1320" width="300" height="95" as="geometry" />
        </mxCell>

        <mxCell id="pg" value="PostgreSQL&#xa;agent_messages / agent_tasks&#xa;agent_human_confirms&#xa;agent_tool_calls&#xa;agent_audit_events / summaries" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#F5F5F5;strokeColor=#666666;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1850" y="875" width="240" height="150" as="geometry" />
        </mxCell>
        <mxCell id="redis" value="Redis&#xa;task hot state&#xa;audit_stream / audit_seq&#xa;sse / idempotency / rule cache" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#F8CECC;strokeColor=#B85450;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1850" y="1070" width="240" height="130" as="geometry" />
        </mxCell>
        <mxCell id="audit" value="AuditWriter → Redis Stream → AuditConsumer → PostgreSQL&#xa;所有关键节点记录 request / intent / context / rule / permission / human_confirm / tool / response" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#C95F5F;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1750" y="1320" width="450" height="115" as="geometry" />
        </mxCell>
        <mxCell id="replay" value="Replay / SSE reconnect&#xa;Last-Event-ID → agent_audit_events&#xa;只回放展示，不重新执行工具" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EAF0FF;strokeColor=#5769F7;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="1750" y="1490" width="450" height="95" as="geometry" />
        </mxCell>

